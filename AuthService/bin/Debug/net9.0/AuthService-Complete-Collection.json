    {
      "name": "🧪 JWT Token & Claims Validation",
      "item": [
        {
          "name": "Decode JWT Token - Verify Claims",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ensure we have a valid, non-revoked token for claims verification",
                  "// Get a fresh token from Login first"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Helper function to decode JWT",
                  "function decodeJWT(token) {",
                  "    var parts = token.split('.');",
                  "    var payload = atob(parts[1]);",
                  "    return JSON.parse(payload);",
                  "}",
                  "",
                  "pm.test(\"Status code is 200 (have valid token)\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Decode and verify JWT claims\", function() {",
                  "    var token = pm.environment.get('jwt_token');",
                  "    if (token && pm.response.code === 200) {",
                  "        var decoded = decodeJWT(token);",
                  "        ",
                  "        // Verify required claims exist",
                  "        pm.expect(decoded).to.have.property('jti'); // Token ID",
                  "        pm.expect(decoded).to.have.property('UserId');",
                  "        pm.expect(decoded).to.have.property('iss'); // Issuer",
                  "        pm.expect(decoded).to.have.property('aud'); // Audience",
                  "        pm.expect(decoded).to.have.property('exp'); // Expiration",
                  "        ",
                  "        console.log('✅ JWT Claims verified: ' + JSON.stringify(decoded, null, 2));",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Verify token issuer is AuthService\", function() {",
                  "    var token = pm.environment.get('jwt_token');",
                  "    if (token && pm.response.code === 200) {",
                  "        var parts = token.split('.');",
                  "        var decoded = JSON.parse(atob(parts[1]));",
                  "        pm.expect(decoded.iss).to.equal('AuthService');",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Verify token audience is FranchiseSystem\", function() {",
                  "    var token = pm.environment.get('jwt_token');",
                  "    if (token && pm.response.code === 200) {",
                  "        var parts = token.split('.');",
                  "        var decoded = JSON.parse(atob(parts[1]));",
                  "        pm.expect(decoded.aud).to.equal('FranchiseSystem');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/sync-users?lastSyncTime=2026-01-01T00:00:00Z",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sync-users"],
              "query": [
                {
                  "key": "lastSyncTime",
                  "value": "2026-01-01T00:00:00Z"
                }
              ]
            }
          }
        }
      ]
