              "name": "Step 1: Login as Admin",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Login successful and token saved\", function() {",
                      "    pm.response.to.have.status(200);",
                      "    var jsonData = pm.response.json();",
                      "    pm.environment.set('workflow_token', jsonData.token);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"username\": \"admin\", \"password\": \"Password@123\"}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              }
            },
            {
              "name": "Step 2: Sync Users with Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"User sync successful\", function() {",
                      "    pm.response.to.have.status(200);",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(Array.isArray(jsonData)).to.be.true;",
                      "    console.log('📋 Users retrieved: ' + jsonData.length);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{workflow_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/auth/sync-users?lastSyncTime=2026-01-01T00:00:00Z",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "sync-users"],
                  "query": [
                    {
                      "key": "lastSyncTime",
                      "value": "2026-01-01T00:00:00Z"
                    }
                  ]
                }
              }
            },
            {
              "name": "Step 3: Logout and Revoke Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Logout successful\", function() {",
                      "    pm.response.to.have.status(200);",
                      "    console.log('✅ Token revoked successfully');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{workflow_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/auth/logout",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "logout"]
                }
