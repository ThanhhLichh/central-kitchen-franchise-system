                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              }
            },
            {
              "name": "Use Token - Before Logout",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Token works before logout\", function() {",
                      "    pm.response.to.have.status(200);",
                      "    console.log('✅ Token is valid');",
