                    "exec": [
                      "pm.test(\"Token rejected after logout\", function() {",
                      "    pm.expect([401, 403]).to.include(pm.response.code);",
                      "    console.log('✅ Blacklist verification passed - token correctly rejected');",
                      "});"
                    ]
