                  "// Test 4: Save token to environment",
                  "pm.test(\"Save token to environment\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('admin_token', jsonData.token);",
                  "    pm.environment.set('jwt_token', jsonData.token);",
                  "    pm.expect(pm.environment.get('jwt_token')).to.exist;",
                  "});",
                  "",
                  "// Test 5: Verify token expiration is in future",
                  "pm.test(\"Token expiration is in the future\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    var expTime = new Date(jsonData.expiration).getTime();",
