          "item": [
            {
              "name": "Prepare: Get Fresh Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Save token for revocation test\", function() {",
                      "    var jsonData = pm.response.json();",
                      "    pm.environment.set('revoke_test_token', jsonData.token);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
